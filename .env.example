# AttentionPay — Configuração de ambiente

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WSS_URL=wss://api.devnet.solana.com

# Program IDs (preencher após deploy)
ATTENTIONPAY_PAYOUT_PROGRAM=PayPolicy111111111111111111111111111111111111
ATTENTIONPAY_LEDGER_PROGRAM=AttnLedg111111111111111111111111111111111111
ATTENTIONPAY_REPUTATION_PROGRAM=RepProof111111111111111111111111111111111111

# Proxy
ATTENTIONPAY_BIND=0.0.0.0:3000
ATTENTIONPAY_NETWORK=devnet

# Segurança (nunca commitar!)
ATTENTIONPAY_TREASURY_KEYPAIR=~/.config/solana/id.json
