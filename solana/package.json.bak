{
  "name": "attentionpay",
  "version": "1.0.0",
  "description": "AttentionPay — Atenção Relativa Ponderada (ARP) on Solana",
  "author": "catitodev",
  "license": "Apache-2.0",
  "scripts": {
    "lint:fix": "prettier */*.js "*/**/*{.js,.ts}" -w",
    "lint": "prettier */*.js "*/**/*{.js,.ts}" --check",
    "build": "anchor build",
    "test": "anchor test",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "deploy:mainnet": "anchor deploy --provider.cluster mainnet"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.91.0",
    "@solana/spl-token": "^0.4.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^4.3.5"
  }
}
